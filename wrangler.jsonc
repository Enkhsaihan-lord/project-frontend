{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "project-frontend",
  "main": ".open-next/worker.js",
  "build": {
    "command": "npm run build:cf"
  },
  "compatibility_date": "2026-06-10",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
